# ProxyPal build-time secrets
# Copy to .env and fill in real values:  cp .env.example .env
# These are injected at compile time via env!() in quota.rs

# Google OAuth credentials for Antigravity token refresh
ANTIGRAVITY_CLIENT_ID=your-client-id.apps.googleusercontent.com
ANTIGRAVITY_CLIENT_SECRET=GOCSPX-your-client-secret
